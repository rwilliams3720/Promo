{
  "version": 2,
  "builds": [
    { "src": "api/upload.js",  "use": "@vercel/node" },
    { "src": "api/history.js", "use": "@vercel/node" },
    { "src": "api/perf.js",    "use": "@vercel/node" },
    { "src": "api/config.js",  "use": "@vercel/node" },
    { "src": "api/admin.js",           "use": "@vercel/node" },
    { "src": "api/stripe-checkout.js", "use": "@vercel/node" },
    { "src": "api/stripe-webhook.js",  "use": "@vercel/node" },
    { "src": "api/stripe-portal.js",   "use": "@vercel/node" },
    { "src": "api/cleanup.js",         "use": "@vercel/node" },
    { "src": "api/invite.js",          "use": "@vercel/node" },
    { "src": "api/members.js",         "use": "@vercel/node" },
    { "src": "api/email-report.js", "use": "@vercel/node" },
    { "src": "api/ai-analysis.js",  "use": "@vercel/node" },
    { "src": "api/delete-account.js", "use": "@vercel/node" },
    { "src": "api/signup.js",          "use": "@vercel/node" },
    { "src": "api/checklist-form.js",  "use": "@vercel/node" },
    { "src": "api/sales.js",           "use": "@vercel/node" },
    { "src": "api/checklist-config.js","use": "@vercel/node" },
    { "src": "api/addon-checkout.js",           "use": "@vercel/node" },
    { "src": "api/member-analysis-checkout.js", "use": "@vercel/node" },
    { "src": "api/member-analysis.js",          "use": "@vercel/node" },
    { "src": "api/member-hours.js",            "use": "@vercel/node" },
    { "src": "api/og.js",              "use": "@vercel/node" },
    { "src": "api/agent-roster.js",    "use": "@vercel/node" },
    { "src": "index.html",    "use": "@vercel/static" },
    { "src": "landing.html",  "use": "@vercel/static" },
    { "src": "favicon.svg",   "use": "@vercel/static" },
    { "src": "og.svg",        "use": "@vercel/static" },
    { "src": "og.png",        "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upload",  "dest": "/api/upload.js"  },
    { "src": "/api/history", "dest": "/api/history.js" },
    { "src": "/api/perf",    "dest": "/api/perf.js"    },
    { "src": "/api/config",  "dest": "/api/config.js"  },
    { "src": "/api/admin",           "dest": "/api/admin.js"           },
    { "src": "/api/stripe-checkout", "dest": "/api/stripe-checkout.js" },
    { "src": "/api/stripe-webhook",  "dest": "/api/stripe-webhook.js"  },
    { "src": "/api/stripe-portal",   "dest": "/api/stripe-portal.js"   },
    { "src": "/api/cleanup",      "dest": "/api/cleanup.js"      },
    { "src": "/api/invite",       "dest": "/api/invite.js"       },
    { "src": "/api/members",      "dest": "/api/members.js"      },
    { "src": "/api/email-report", "dest": "/api/email-report.js" },
    { "src": "/api/ai-analysis",    "dest": "/api/ai-analysis.js"    },
    { "src": "/api/delete-account", "dest": "/api/delete-account.js" },
    { "src": "/api/signup",           "dest": "/api/signup.js"           },
    { "src": "/api/checklist-form",   "dest": "/api/checklist-form.js"   },
    { "src": "/api/sales",            "dest": "/api/sales.js"            },
    { "src": "/api/checklist-config", "dest": "/api/checklist-config.js" },
    { "src": "/api/addon-checkout",            "dest": "/api/addon-checkout.js"           },
    { "src": "/api/member-analysis-checkout", "dest": "/api/member-analysis-checkout.js" },
    { "src": "/api/member-analysis",          "dest": "/api/member-analysis.js"          },
    { "src": "/api/member-hours",            "dest": "/api/member-hours.js"            },
    { "src": "/api/og",               "dest": "/api/og.js"               },
    { "src": "/api/agent-roster",     "dest": "/api/agent-roster.js"     },
    { "src": "/favicon.svg",  "dest": "/favicon.svg"    },
    { "src": "/og.svg",       "dest": "/og.svg"         },
    { "src": "/og.png",       "dest": "/og.png"         },
    { "src": "/",             "dest": "/landing.html"   },
    { "src": "/(.*)",         "dest": "/index.html"     }
  ],
  "crons": [
    { "path": "/api/cleanup",      "schedule": "0 3 1 * *" },
    { "path": "/api/email-report", "schedule": "0 * * * *" }
  ]
}
