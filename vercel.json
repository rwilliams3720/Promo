{
  "version": 2,
  "builds": [
    {
      "src": "api/sheet.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/upload.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/history.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/perf.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/sheet",
      "dest": "/api/sheet.js"
    },
    {
      "src": "/api/upload",
      "dest": "/api/upload.js"
    },
    {
      "src": "/api/history",
      "dest": "/api/history.js"
    },
    {
      "src": "/api/perf",
      "dest": "/api/perf.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
